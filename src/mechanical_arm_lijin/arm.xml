<mujoco model="Optimized 3DOF Robotic Arm">
  <compiler angle="radian" inertiafromgeom="true" autolimits="true"/>

  <!-- 基础物理设置（仅保留旧版本兼容属性） -->
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <!-- 视觉设置（极简兼容版） -->
  <visual>
    <global azimuth="135" elevation="-30"/>
  </visual>

  <!-- 简化的资产定义 -->
  <asset>
    <material name="base_metal" rgba="0.3 0.3 0.3 1"/>
    <material name="upper_arm_metal" rgba="0.7 0.2 0.2 1"/>
    <material name="lower_arm_metal" rgba="0.2 0.7 0.2 1"/>
    <material name="ee_metal" rgba="0.2 0.2 0.7 1"/>
    <material name="floor_mat" rgba="0.6 0.6 0.6 1"/>
    <material name="joint_mat" rgba="0.1 0.1 0.1 1"/>
  </asset>

  <!-- 世界体（简化语法，兼容旧版本） -->
  <worldbody>
    <!-- 地面 -->
    <geom name="floor" type="plane" size="5 5 0.1" pos="0 0 0" material="floor_mat" friction="1.0 0.1 0.01"/>

    <!-- 机械臂基座 -->
    <body name="base" pos="0 0 0">
      <geom name="base_geom" type="cylinder" size="0.15 0.08" pos="0 0 0" material="base_metal" mass="2.0"/>
      <joint name="joint1" type="hinge" axis="0 0 1" pos="0 0 0" range="-3.14 3.14" damping="0.5" limited="true"/>
      <geom name="joint1_geom" type="cylinder" size="0.08 0.02" pos="0 0 0.08" material="joint_mat"/>

      <!-- 大臂 -->
      <body name="upper_arm" pos="0 0 0.08">
        <geom name="upper_arm_geom" type="capsule" size="0.06" fromto="0 0 0 0 0 0.4" material="upper_arm_metal" mass="0.8"/>
        <joint name="joint2" type="hinge" axis="1 0 0" pos="0 0 0.4" range="-1.57 1.57" damping="0.4" limited="true"/>
        <geom name="joint2_geom" type="cylinder" size="0.07 0.02" pos="0 0 0.4" material="joint_mat"/>

        <!-- 小臂 -->
        <body name="lower_arm" pos="0 0 0.4">
          <geom name="lower_arm_geom" type="capsule" size="0.05" fromto="0 0 0 0 0 0.35" material="lower_arm_metal" mass="0.5"/>
          <joint name="joint3" type="hinge" axis="1 0 0" pos="0 0 0.35" range="-1.57 1.57" damping="0.3" limited="true"/>
          <geom name="joint3_geom" type="cylinder" size="0.06 0.02" pos="0 0 0.35" material="joint_mat"/>

          <!-- 末端执行器 -->
          <body name="end_effector" pos="0 0 0.35">
            <geom name="ee_base_geom" type="cylinder" size="0.04 0.03" pos="0 0 0" material="ee_metal" mass="0.1"/>
            <geom name="ee_tip_geom" type="sphere" size="0.03" pos="0 0 0.03" material="ee_metal"/>
            <site name="ee_site" pos="0 0 0.03" size="0.01" rgba="1 1 1 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- 简化的控制器（仅保留旧版本支持的属性） -->
  <actuator>
    <position name="act1" joint="joint1" kp="1500"/>
    <position name="act2" joint="joint2" kp="1200"/>
    <position name="act3" joint="joint3" kp="1000"/>
  </actuator>

  <!-- 基础传感器（兼容旧版本） -->
  <sensor>
    <jointpos name="joint1_pos" joint="joint1"/>
    <jointpos name="joint2_pos" joint="joint2"/>
    <jointpos name="joint3_pos" joint="joint3"/>
    <jointvel name="joint1_vel" joint="joint1"/>
    <jointvel name="joint2_vel" joint="joint2"/>
    <jointvel name="joint3_vel" joint="joint3"/>
    <framepos name="ee_pos" objtype="site" objname="ee_site"/>
  </sensor>
</mujoco>