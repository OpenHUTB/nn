<mujoco model="six_axis_robotic_arm">
  <compiler angle="degree" inertiafromgeom="true"/>
  <option timestep="0.001" gravity="0 0 -9.81"/>

  <!-- 视觉材质 -->
  <asset>
    <material name="blue" rgba="0 0 1 1"/>
    <material name="red" rgba="1 0 0 1"/>
    <material name="gray" rgba="0.5 0.5 0.5 1"/>
  </asset>

  <!-- 世界体（基座） -->
  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" diffuse="1 1 1"/>
    <!-- 修复：移除lookat，用xyaxes定义相机朝向（兼容所有MuJoCo版本） -->
    <camera name="fixed_cam" pos="0 -1.5 1" xyaxes="1 0 0 0 0.5 1"/>

    <!-- 基座（修复：固定关节不指定type，默认就是固定） -->
    <body name="base" pos="0 0 0">
      <geom name="base_geom" type="box" size="0.15 0.15 0.05" material="gray"/>
      <!-- 移除type="fixed"，MuJoCo中无type的joint默认是固定关节 -->
      <joint name="joint0"/>

      <!-- 关节1（绕Z轴旋转） -->
      <body name="link1" pos="0 0 0.1">
        <geom name="link1_geom" type="cylinder" size="0.05 0.1" material="blue" pos="0 0 0.1"/>
        <joint name="joint1" type="hinge" axis="0 0 1" range="-180 180" damping="0.1"/>

        <!-- 关节2（绕Y轴旋转） -->
        <body name="link2" pos="0 0 0.2">
          <geom name="link2_geom" type="cylinder" size="0.04 0.2" material="blue" pos="0.1 0 0"/>
          <joint name="joint2" type="hinge" axis="0 1 0" range="-90 90" damping="0.1"/>

          <!-- 关节3（绕Y轴旋转） -->
          <body name="link3" pos="0.2 0 0">
            <geom name="link3_geom" type="cylinder" size="0.04 0.18" material="blue" pos="0.09 0 0"/>
            <joint name="joint3" type="hinge" axis="0 1 0" range="-90 90" damping="0.1"/>

            <!-- 关节4（绕Z轴旋转） -->
            <body name="link4" pos="0.18 0 0">
              <geom name="link4_geom" type="cylinder" size="0.03 0.15" material="blue" pos="0 0 0.075"/>
              <joint name="joint4" type="hinge" axis="0 0 1" range="-180 180" damping="0.1"/>

              <!-- 关节5（绕Y轴旋转） -->
              <body name="link5" pos="0 0 0.15">
                <geom name="link5_geom" type="cylinder" size="0.03 0.08" material="blue" pos="0 0 0.04"/>
                <joint name="joint5" type="hinge" axis="0 1 0" range="-90 90" damping="0.1"/>

                <!-- 关节6（绕Z轴旋转） -->
                <body name="link6" pos="0 0 0.08">
                  <geom name="link6_geom" type="sphere" size="0.05" material="red"/>
                  <joint name="joint6" type="hinge" axis="0 0 1" range="-360 360" damping="0.1"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- 控制器：位置控制（兼容所有MuJoCo版本） -->
  <actuator>
    <position name="act1" joint="joint1" kp="1000" kv="100"/>
    <position name="act2" joint="joint2" kp="1000" kv="100"/>
    <position name="act3" joint="joint3" kp="1000" kv="100"/>
    <position name="act4" joint="joint4" kp="1000" kv="100"/>
    <position name="act5" joint="joint5" kp="1000" kv="100"/>
    <position name="act6" joint="joint6" kp="1000" kv="100"/>
  </actuator>
</mujoco>